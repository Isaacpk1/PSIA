      "parameters": {
        "jsCode": "// 1. Pega apenas as 5 primeiras notícias (as mais recentes)\nconst noticias = $input.all().slice(0, 5);\n\n// 2. Cria a instrução inicial blindada\nlet textoParaIA = \"Aqui estão as principais notícias de Inteligência Artificial de hoje. Use EXATAMENTE os links e títulos fornecidos abaixo. Não invente dados.\\n\\n\";\n\n// 3. Faz o loop para organizar os dados\nnoticias.forEach((item, index) => {\n  textoParaIA += `Notícia ${index + 1}:\\n`;\n  textoParaIA += `Título: ${item.json.title}\\n`;\n  textoParaIA += `Conteúdo: ${item.json.contentSnippet}\\n`; \n  textoParaIA += `Link original: ${item.json.link}\\n`;\n  \n  // Enviando a data exata para a IA calcular o \"Há x horas\"\n  textoParaIA += `Data de Publicação: ${item.json.pubDate}\\n`; \n  \n  // Como confirmamos que o Google News não manda a foto, já enviamos como nulo\n  textoParaIA += `Link da imagem: Sem imagem fornecida\\n`; \n  \n  textoParaIA += `------------------------\\n\\n`;\n});\n\n// 4. Devolve tudo empacotado em 1 único item para a IA ler!\nreturn [{ json: { textoAgrupado: textoParaIA } }];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        -64
      ],
      "id": "4e03448b-4240-4bb6-bbbb-a82759baab48",
